.buttonlogin {
  background-color: #4e60ff;
  color: #ffffff;
  width: 350px;
  height: 44px;
  border: none;
  border-radius: 6px;
  margin-top: 40px;
  margin-bottom: 16px;
}

.buttonlogin:hover {
  animation: ruso 2s forwards infinite;
}

@keyframes ruso {
  50% {
    background-color: red;
  }
  100% {
    scale: 2;
    background-color: red;
    margin-left: 200px;
  }
}
.forgotpassword {
  color: #4e60ff;
  font-size: 14px;
