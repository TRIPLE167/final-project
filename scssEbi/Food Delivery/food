@import url("https://fonts.googleapis.com/css2?family=Nunito+Sans:opsz@6..12&display=swap");
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.parent {
  display: flex;
}

.child1 {
  width: 640px;
  height: 100vh;
  display: flex;
  justify-content: center;
}

header {
  font-size: 44px;
  font-weight: 700;
  margin-top: 20px;
}

.food {
  color: #2b2b43;
}

.delivery {
  color: #4e60ff;
  display: block;
}

.login {
  margin-top: 128px;
  font-size: 60px;
  font-family: nunito;
  font-weight: 700;
}

p {
  margin-top: 16px;
  margin-bottom: 32px;
  font-size: 14px;
  font-family: nunito;
  font-weight: 400;
}

.labels {
  display: flex;
  flex-direction: column;
}

input:not(.ptsichka) {
  width: 350px;
  height: 44px;
  border-radius: 8px;
  border: 1px solid gray;
  margin-bottom: 28px;
  padding-left: 12px;
}

.labels label {
  margin-bottom: 4px;
}

/* .checkbox {
  width: 318px;
